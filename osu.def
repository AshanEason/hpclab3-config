Bootstrap: docker
From: ubuntu:24.04

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates wget build-essential openmpi-bin libopenmpi-dev

    cd /opt
    wget -q https://mvapich.cse.ohio-state.edu/download/mvapich/osu-micro-benchmarks-7.5.1.tar.gz
    tar -xzf osu-micro-benchmarks-7.5.1.tar.gz
    cd osu-micro-benchmarks-7.5.1
    ./configure CC=mpicc CXX=mpicxx --prefix=/opt/osu
    make -j2
    make install

    rm -rf /opt/osu-micro-benchmarks-7.5.1 /opt/osu-micro-benchmarks-7.5.1.tar.gz
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    export PATH=/opt/osu/libexec/osu-micro-benchmarks/mpi:$PATH

%runscript
    exec /opt/osu/libexec/osu-micro-benchmarks/mpi/"$@"
